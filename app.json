{
  "expo": {
    "name": "Remediologio",
    "slug": "Remediologio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons8-alarm-clock-glyph-neue-16.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons8-alarm-clock-glyph-neue-96.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons8-alarm-clock-glyph-neue-72.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icons8-alarm-clock-glyph-neue-16.png"
    },
    "plugins": [
      ["expo-router"],

      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Rajdhani-SemiBold.ttf"]
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}
